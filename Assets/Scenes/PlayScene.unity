  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 849dd09d0b8143d43ac134920f873f97, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  tutorialPanel: {fileID: 1714516250}
  playerPortraitImage: {fileID: 1506911967}
  tutorialTextMesh: {fileID: 1416001379}
  nextButton: {fileID: 554848933}
  levelTutorials:
  - targetLevel: 1
    dialogueLines:
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "Ch\xE0o m\u1EEBng b\u1EA1n \u0111\u1EBFn n\xF4ng tr\u1EA1i..."
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "B\u1EA1n h\xE3y \u0111i x\xE2y d\u1EF1ng n\xF4ng tr\u1EA1i c\u1EE7a
        m\xECnh b\u1EB1ng vi\u1EC7c nh\u1EA5n ph\xEDm ( C ) \u0111\u1EC3 \u0111\xE0o
        \u0111\u1EA5t v\xE0 tr\u1ED3ng c\xE2y ng\xF4 b\u1EB1ng ph\xEDm ( V ) nh\xE9 
        !"
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "Ngo\xE0i ra b\u1EA1n h\xE3y nh\u1EA5n ph\xEDm ( T ) \u0111\u1EC3
        m\u1EDF t\xFAi \u0111\u1ED3 nh\xE9. Ch\xFAc b\u1EA1n x\xE2y trang tr\u1EA1i
        vui v\u1EBB ^^"
  - targetLevel: 2
    dialogueLines:
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "Ch\xFAc m\u1EEBng b\u1EA1n \u0111\xE3 l\xEAn c\u1EA5p! B\xE2y
        gi\u1EDD b\u1EA1n \u0111\xE3 l\xE0 m\u1ED9t ng\u01B0\u1EDDi n\xF4ng d\xE2n
        th\u1EF1c th\u1EE5 r\u1ED3i \u0111\u1EA5y."
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "T\u1EEB gi\u1EDD, b\u1EA1n c\xF3 th\u1EC3 tr\u1ED3ng c\xE2y
        c\xE0 chua b\u1EB1ng c\xE1ch nh\u1EA5m ph\xEDm ( B )  nh\xE9!"
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "B\u1EA1n c\u0169ng c\xF3 th\u1EC3 n\xE2ng c\u1EA5p ng\xF4i nh\xE0
        c\u1EE7a m\xECnh b\u1EB1ng c\xE1ch nh\u1EA5n v\xE0o n\xFAt \"N\xE2ng c\u1EA5p\"
        nh\xE9!"
    - playerPortrait: {fileID: 21300000, guid: 21ae12909dfa64464820da55fc494021, type: 3}
      dialogueText: "H\xE3y c\u1ED1 g\u1EAFng l\xEAn ch\u1EC9 c\u1EA7n \u0111\u1EA1t
        \u0111\u1EE7 300 v\xE0ng l\xE0 b\u1EA1n ph\xE1 \u0111\u1EA3o r\u1ED3i \u0111\xF3
        <3"
